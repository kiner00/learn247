APP_NAME="Curzzo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_SERVER_IP=
APP_TIMEZONE=Asia/Manila

# ── Octane ─────────────────────────────────────────────────────────────────────
OCTANE_SERVER=frankenphp
OCTANE_HTTPS=false

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=curzzo
DB_USERNAME=sail
DB_PASSWORD=password

# ── Cache / Queue / Session ────────────────────────────────────────────────────
BROADCAST_CONNECTION=reverb
CACHE_STORE=redis
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail (Mailpit for local) ───────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@curzzo.test"
MAIL_FROM_NAME="${APP_NAME}"

# ── Xendit ─────────────────────────────────────────────────────────────────────
# Get your keys from https://dashboard.xendit.co/settings/developers
XENDIT_SECRET_KEY=xnd_development_XXXXXXXXXXXXXXXXXXXXXXXX
XENDIT_PUBLIC_KEY=xnd_public_development_XXXXXXXXXXXXXXXXXXXXXXXX
# Xendit dashboard → Webhook Settings → Callback token
XENDIT_CALLBACK_TOKEN=your_xendit_callback_token_here

# ── AI Assistant ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── Ploi (custom domain provisioning) ─────────────────────────────────────────
# API token: ploi.io → Profile → API Tokens → Create token
PLOI_API_TOKEN=
# Find server/site IDs in the Ploi URL when you open the site:
# https://ploi.io/servers/{PLOI_SERVER_ID}/sites/{PLOI_SITE_ID}
PLOI_SERVER_ID=
PLOI_SITE_ID=

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=curzzo-dev
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Reverb (WebSocket) ─────────────────────────────────────────────────────────
REVERB_APP_ID=curzzo-local
REVERB_APP_KEY=curzzo-reverb-key
REVERB_APP_SECRET=curzzo-reverb-secret
REVERB_HOST="localhost"
REVERB_PORT=6001
REVERB_SCHEME=http
REVERB_SERVER_PORT=6001

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ── Vite ───────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_APP_ENV="${APP_ENV}"

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
# Only sends events when APP_ENV=production. DSNs below are ignored in local/staging.
# Create a project at sentry.io → Settings → Client Keys (DSN).
# Backend DSN and frontend DSN are separate projects.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false

VITE_SENTRY_DSN_PUBLIC=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
